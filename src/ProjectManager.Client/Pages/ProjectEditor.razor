@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using ProjectManager.Client.Services
@using ProjectManager.Contracts
@inject ProjectApiClient Api

<div class="modal-backdrop" @onclick="OnCancel">
    <div class="modal" @onclick:stopPropagation="true">
        <h3>@(IsEdit ? "Upraviť projekt" : "Nový projekt")</h3>
        <EditForm Model="@_model" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <div class="field">
                <label>Názov</label>
                <InputText class="input" @bind-Value="_model.Name" />
                <ValidationMessage For="@(() => _model.Name)" />
            </div>
            <div class="field">
                <label>Skratka</label>
                <InputText class="input" @bind-Value="_model.Abbreviation" />
                <ValidationMessage For="@(() => _model.Abbreviation)" />
            </div>
            <div class="field">
                <label>Zákazník</label>
                <InputText class="input" @bind-Value="_model.Customer" />
                <ValidationMessage For="@(() => _model.Customer)" />
            </div>

            @if (_error is not null)
            {
                <div class="alert alert-error">@_error</div>
            }

            <div class="modal-actions">
                <button class="btn btn-ghost" type="button" @onclick="OnCancel">Zrušiť</button>
                <button class="btn btn-primary" type="submit">Uložiť</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public ProjectDto? Project { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private readonly Model _model = new();
    private string? _error;
    private bool IsEdit => Project is not null;

    protected override void OnParametersSet()
    {
        _model.Name = Project?.Name ?? "";
        _model.Abbreviation = Project?.Abbreviation ?? "";
        _model.Customer = Project?.Customer ?? "";
    }

    private async Task Save()
    {
        _error = null;
        try
        {
            var res = IsEdit
                ? await Api.UpdateAsync(Project!.Id, new UpdateProjectRequest(_model.Name, _model.Abbreviation, _model.Customer))
                : await Api.CreateAsync(new CreateProjectRequest(_model.Name, _model.Abbreviation, _model.Customer));

            if (res.IsSuccessStatusCode) { await OnSaved.InvokeAsync(); return; }
            _error = await DescribeErrorAsync(res);
        }
        catch
        {
            _error = "Nepodarilo sa spojiť so serverom.";
        }
    }

    // Turns a non-success response into a human message: a friendly text for a known conflict,
    // otherwise the server's RFC 7807 ProblemDetails (validation errors / detail / title).
    private static async Task<string> DescribeErrorAsync(HttpResponseMessage res)
    {
        if (res.StatusCode == System.Net.HttpStatusCode.Conflict)
            return "Projekt s touto skratkou už existuje.";

        try
        {
            var problem = await res.Content.ReadFromJsonAsync<ProblemResponse>();
            if (problem?.Errors is { Count: > 0 })
                return string.Join(" ", problem.Errors.SelectMany(e => e.Value));
            if (!string.IsNullOrWhiteSpace(problem?.Detail))
                return problem!.Detail!;
            if (!string.IsNullOrWhiteSpace(problem?.Title))
                return problem!.Title!;
        }
        catch
        {
            // Response body was not problem+json; fall back to a generic message.
        }

        return "Uloženie zlyhalo. Skontrolujte vstupy.";
    }

    private sealed record ProblemResponse(string? Title, string? Detail, Dictionary<string, string[]>? Errors);

    // Mirrors the server-side FluentValidation rules (CreateProjectValidator/UpdateProjectValidator)
    // so invalid input is caught before a round-trip; the API stays the source of truth.
    private sealed class Model
    {
        [Required(ErrorMessage = "Názov je povinný.")]
        [StringLength(200, ErrorMessage = "Názov môže mať najviac 200 znakov.")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Skratka je povinná.")]
        [StringLength(50, ErrorMessage = "Skratka môže mať najviac 50 znakov.")]
        public string Abbreviation { get; set; } = "";

        [Required(ErrorMessage = "Zákazník je povinný.")]
        [StringLength(200, ErrorMessage = "Zákazník môže mať najviac 200 znakov.")]
        public string Customer { get; set; } = "";
    }
}
