@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using ProjectManager.Client.Services
@using ProjectManager.Contracts
@inject ProjectApiClient Api

<div class="page-head reveal">
    <div class="title">
        <span class="eyebrow">Firemné projekty</span>
        <h1>Projekty</h1>
        @if (_projects is not null)
        {
            <span class="count">@_projects.Count @(Plural(_projects.Count))</span>
        }
    </div>
    <button class="btn btn-primary" @onclick="@(() => OpenEditor(null))">＋ Nový projekt</button>
</div>

@if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}

@if (_projects is null)
{
    <div class="panel">
        <div class="muted-block"><span class="spinner"></span>Načítavam projekty…</div>
    </div>
}
else if (_projects.Count == 0)
{
    <div class="panel reveal-2">
        <div class="empty">
            <h3>Zatiaľ žiadne projekty</h3>
            <p>Vytvorte prvý projekt firmy.</p>
            <button class="btn btn-primary" @onclick="@(() => OpenEditor(null))">＋ Nový projekt</button>
        </div>
    </div>
}
else
{
    <div class="panel reveal-2">
        <table class="data-table">
            <thead>
                <tr><th>Názov</th><th>Skratka</th><th>Zákazník</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var p in _projects)
                {
                    <tr>
                        <td class="name">@p.Name</td>
                        <td><span class="chip">@p.Abbreviation</span></td>
                        <td class="cust">@p.Customer</td>
                        <td class="td-actions">
                            <div class="row-actions">
                                <button class="btn btn-ghost btn-sm" @onclick="@(() => OpenEditor(p))">Upraviť</button>
                                <button class="btn btn-danger-ghost btn-sm" @onclick="@(() => Delete(p.Id))">Zmazať</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_editing)
{
    <ProjectEditor Project="_selected" OnSaved="OnSaved" OnCancel="@(() => _editing = false)" />
}

@code {
    private List<ProjectDto>? _projects;
    private bool _editing;
    private ProjectDto? _selected;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _error = null;
        try
        {
            var projects = await Api.GetAllAsync();
            if (projects is null)
            {
                _error = "Projekty sa nepodarilo načítať (neautorizované alebo chyba servera).";
                _projects = new();
            }
            else
            {
                _projects = projects;
            }
        }
        catch
        {
            _error = "Nepodarilo sa spojiť so serverom.";
            _projects = new();
        }
    }

    private void OpenEditor(ProjectDto? p) { _selected = p; _editing = true; }

    private async Task OnSaved() { _editing = false; await Load(); }

    private async Task Delete(string id)
    {
        _error = null;
        var res = await Api.DeleteAsync(id);
        if (res.IsSuccessStatusCode)
            await Load();
        else
            _error = "Zmazanie zlyhalo.";
    }

    private static string Plural(int n) => n == 1 ? "záznam" : (n >= 2 && n <= 4 ? "záznamy" : "záznamov");
}
