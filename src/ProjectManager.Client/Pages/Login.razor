@page "/login"
@using System.ComponentModel.DataAnnotations
@using ProjectManager.Client.Auth
@using ProjectManager.Client.Resources
@using ProjectManager.Client.Services
@using ProjectManager.Contracts
@inject AuthApiClient AuthApi
@inject JwtAuthenticationStateProvider AuthState
@inject NavigationManager Nav

<div class="login-shell">
    <div class="login-card reveal">
        <span class="eyebrow">Firemné projekty</span>
        <h1>Správa projektov</h1>
        <p class="login-sub">Prihláste sa pre prístup k zoznamu projektov.</p>

        <EditForm Model="@_model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <div class="field">
                <label>Používateľ</label>
                <InputText class="input" @bind-Value="_model.Username" autocomplete="username" />
                <ValidationMessage For="@(() => _model.Username)" />
            </div>
            <div class="field">
                <label>Heslo</label>
                <InputText class="input" type="password" @bind-Value="_model.Password" autocomplete="current-password" />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            @if (_error is not null)
            {
                <div class="alert alert-error">@_error</div>
            }

            <button class="btn btn-primary" type="submit" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner"></span>
                }
                Prihlásiť sa
            </button>
        </EditForm>

        <div class="login-hint">demo &middot; admin / Admin123!</div>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _busy;
    private string? _error;

    private async Task Submit()
    {
        _busy = true;
        _error = null;
        try
        {
            var response = await AuthApi.LoginAsync(new LoginRequest(_model.Username, _model.Password));
            if (response is null)
            {
                _error = AppMessages.InvalidCredentials;
                return;
            }

            AuthState.SetToken(response.Token);
            Nav.NavigateTo("/");
        }
        catch
        {
            _error = AppMessages.ServerUnavailable;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessageResourceType = typeof(AppMessages), ErrorMessageResourceName = nameof(AppMessages.UsernameRequired))]
        public string Username { get; set; } = "";

        [Required(ErrorMessageResourceType = typeof(AppMessages), ErrorMessageResourceName = nameof(AppMessages.PasswordRequired))]
        public string Password { get; set; } = "";
    }
}
